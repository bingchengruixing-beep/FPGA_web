module clk_div(
    input           clk,
    input           rst_n,
    output  reg     sample_en
);

parameter DIV_CNT = 50;

reg [31:0] cnt;

always @(posedge clk or negedge rst_n) begin
    if (!rst_n) begin
        cnt       <= 32'd0;
        sample_en <= 1'b0;
    end
    else begin
        if (cnt == DIV_CNT - 1) begin
            cnt       <= 32'd0;
            sample_en <= 1'b1;
        end
        else begin
            cnt       <= cnt + 1'b1;
            sample_en <= 1'b0;
        end
    end
end

endmodule